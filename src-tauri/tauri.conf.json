{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Web-Tauri-秦曱凧",
  "version": "1.3.0",
  "identifier": "com.win.web-tauri",
  "plugins": {
    "webview": {
      "browser_args": [
        "--ignore-certificate-errors",
        "--allow-running-insecure-content",
        "--disable-web-security",
        "--disable-features=VizDisplayCompositor"
      ]
    }
  },
  "build": {
    "frontendDist": "../代码"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/icon.ico"
    ]
  }
}
